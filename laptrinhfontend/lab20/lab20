<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <title>Bài Lab 20 - Gửi thêm mới dữ liệu bằng Ajax POST</title>
    <script src="https://code.jquery.com/jquery-3.6.4.min.js"></script>
    <style>
        body { font-family: Arial, sans-serif; margin: 30px; background-color: #f4f7f6; }
        .container { max-width: 450px; margin: 0 auto; padding: 25px; background: white; border-radius: 8px; box-shadow: 0 4px 8px rgba(0,0,0,0.1); }
        .form-group { margin-bottom: 12px; }
        label { display: block; margin-bottom: 5px; font-weight: bold; }
        input { width: 100%; padding: 8px; box-sizing: border-box; border: 1px solid #ccc; border-radius: 4px; }
        button { background-color: #27ae60; color: white; border: none; padding: 10px 15px; width: 100%; border-radius: 4px; cursor: pointer; font-size: 16px; font-weight: bold; }
        button:hover { background-color: #219150; }
        .success-box { margin-top: 15px; padding: 12px; background-color: #e8f8f5; border: 1px solid #2ecc71; border-radius: 4px; color: #27ae60; display: none; font-size: 14px;}
    </style>
</head>
<body>
    <div class="container">
        <h2>Thêm Nhân Sự Mới (Ajax POST)</h2>
        <form id="employeeForm">
            <div class="form-group">
                <label for="empName">Họ và tên nhân viên:</label>
                <input type="text" id="empName" placeholder="Nhập tên nhân sự mới">
            </div>
            <div class="form-group">
                <label for="empJob">Vị trí chức vụ làm việc:</label>
                <input type="text" id="empJob" placeholder="Ví dụ: Lập trình viên C++">
            </div>
            <button type="submit">Gửi thông tin thêm mới</button>
        </form>

        <div class="success-box" id="postResponseBox"></div>
    </div>

    <script>
        $(document).ready(function() {
            $("#employeeForm").submit(function(e) {
                e.preventDefault(); // Ngăn chặn sự kiện submit tải lại trang web mặc định

                let nameInput = $("#empName").val().trim();
                let jobInput = $("#empJob").val().trim();

                if (nameInput === "" || jobInput === "") {
                    alert("Vui lòng nhập điền đầy đủ thông tin các trường yêu cầu dữ liệu!");
                    return;
                }

                // Thực hiện cấu trúc lệnh gửi yêu cầu kết nối Ajax POST dữ liệu lên máy chủ ảo
                $.ajax({
                    url: "https://reqres.in/api/users",
                    type: "POST",
                    contentType: "application/json",
                    data: JSON.stringify({
                        name: nameInput,
                        job: jobInput
                    }),
                    success: function(response) {
                        // Hiển thị hộp thoại banner thông báo phản hồi dữ liệu trả về từ máy chủ thành công
                        $("#postResponseBox").html(`
                            <b>Thêm mới thành công dữ liệu nhân sự lên Server!</b><br>
                            Mã số sinh tự động: <b>#${response.id}</b><br>
                            Tên nhân viên: ${response.name}<br>
                            Chức vụ làm việc: ${response.job}<br>
                            Thời điểm ghi nhận: ${response.createdAt}
                        `).slideDown(300);

                        // Yêu cầu mở rộng: Tiến hành xóa dọn dẹp sạch dữ liệu ô input sau khi hoàn tất thành công
                        $("#employeeForm")[0].reset();
                    },
                    error: function(xhr, status, error) {
                        alert("Gặp sự cố lỗi trong tiến trình gửi gói tin POST: " + error);
                    }
                });
            });
        });
    </script>
</body>
</html>