<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <title>Bài Lab 04 - Xử lý điểm sinh viên</title>
    <style>
        body { font-family: Arial, sans-serif; margin: 30px; background-color: #f4f7f6; }
        .container { max-width: 500px; padding: 20px; background: white; border-radius: 8px; box-shadow: 0 4px 8px rgba(0,0,0,0.1); }
        .score-list { background: #eee; padding: 10px; border-radius: 4px; font-weight: bold; letter-spacing: 1px; }
        .result-box { margin-top: 15px; padding: 15px; background: #e8f8f5; border-left: 5px solid #1abc9c; }
        .form-add { margin-top: 15px; display: flex; gap: 10px; }
        .form-add input { flex: 1; padding: 8px; border: 1px solid #ccc; border-radius: 4px; }
        .form-add button { background: #1abc9c; color: white; border: none; padding: 8px 12px; border-radius: 4px; cursor: pointer; }
    </style>
</head>
<body>
    <div class="container">
        <h2>Xử Lý Danh Sách Điểm Sinh Viên</h2>
        <p>Danh sách điểm hiện tại trong hệ thống:</p>
        <div class="score-list" id="scoreDisplay"></div>

        <div class="form-add">
            <input type="number" id="newScore" min="0" max="10" step="0.1" placeholder="Nhập điểm mới (0-10)">
            <button onclick="addScore()">Thêm điểm</button>
        </div>

        <div class="result-box" id="resultBox"></div>
    </div>

    <script>
        // Khởi tạo mảng dữ liệu điểm gốc có 5 phần tử mẫu
        let scores = [7.5, 8.2, 5.0, 9.1, 6.4];

        function renderScores() {
            // Hiển thị mảng điểm
            document.getElementById('scoreDisplay').innerText = scores.join(" | ");

            let sum = 0;
            // Sử dụng forEach duyệt mảng tính tổng điểm
            scores.forEach(function(score) {
                sum += score;
            });

            // Tính điểm trung bình của hệ thống
            let avg = (sum / scores.length).toFixed(2);
            let rank = "";

            // Thuật toán phân loại học lực theo các ngưỡng quy định
            if (avg >= 8.5) rank = "Giỏi";
            else if (avg >= 7.0) rank = "Khá";
            else if (avg >= 5.0) rank = "Trung bình";
            else rank = "Yếu";

            // Hiển thị ra màn hình thông tin chi tiết
            document.getElementById('resultBox').innerHTML = `
                <strong>Số lượng bài kiểm tra:</strong> ${scores.length}<br>
                <strong>Điểm tổng cộng:</strong> ${sum.toFixed(1)}<br>
                <strong>Điểm trung bình học phần:</strong> ${avg}<br>
                <strong>Phân loại học lực:</strong> <span style="color:#e74c3c; font-weight:bold;">${rank}</span>
            `;
        }

        function addScore() {
            const input = document.getElementById('newScore');
            const value = parseFloat(input.value);

            if (isNaN(value) || value < 0 || value > 10) {
                alert("Vui lòng nhập điểm hợp lệ trong khoảng từ 0 đến 10!");
                return;
            }

            scores.push(value); // Thêm phần tử mới vào mảng
            input.value = "";
            renderScores(); // Vẽ lại giao diện đồng bộ
        }

        // Thực thi hàm tính toán hiển thị lần đầu tiên
        window.onload = renderScores;
    </script>
</body>
</html>