<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <title>Bài Lab 01 - Tính chỉ số BMI</title>
    <style>
        body { font-family: Arial, sans-serif; margin: 30px; background-color: #f4f7f6; }
        .container { max-width: 400px; padding: 20px; background: white; border-radius: 8px; box-shadow: 0 4px 8px rgba(0,0,0,0.1); }
        .form-group { margin-bottom: 15px; }
        label { display: block; margin-bottom: 5px; font-weight: bold; }
        input { width: 100%; padding: 8px; box-sizing: border-box; border: 1px solid #ccc; border-radius: 4px; }
        button { background-color: #27ae60; color: white; border: none; padding: 10px 15px; width: 100%; border-radius: 4px; cursor: pointer; font-size: 16px; }
        button:hover { background-color: #219150; }
        #result { margin-top: 20px; padding: 15px; border-radius: 4px; font-weight: bold; text-align: center; font-size: 18px; display: none; }
    </style>
</head>
<body>
    <div class="container">
        <h2>Tính Chỉ Số BMI</h2>
        <div class="form-group">
            <label for="height">Chiều cao (m):</label>
            <input type="number" id="height" step="0.01" placeholder="Ví dụ: 1.72">
        </div>
        <div class="form-group">
            <label for="weight">Cân nặng (kg):</label>
            <input type="number" id="weight" step="0.1" placeholder="Ví dụ: 65">
        </div>
        <button onclick="calculateBMI()">Tính toán</button>
        <div id="result"></div>
    </div>

    <script>
        function calculateBMI() {
            const heightInput = document.getElementById('height').value;
            const weightInput = document.getElementById('weight').value;
            const resultDiv = document.getElementById('result');

            // Yêu cầu mở rộng: Kiểm tra dữ liệu rỗng, dữ liệu âm hoặc chiều cao bằng 0
            if (!heightInput || !weightInput) {
                alert("Vui lòng nhập đầy đủ chiều cao và cân nặng!");
                return;
            }
            
            const height = Number(heightInput);
            const weight = Number(weightInput);

            if (height <= 0 || weight <= 0) {
                alert("Chiều cao và cân nặng phải lớn hơn 0!");
                return;
            }

            // Tính toán BMI làm tròn đến 2 chữ số thập phân
            const bmi = (weight / (height * height)).toFixed(2);
            let classification = "";
            let color = "";

            // Phân loại thể trạng và đổi màu sắc tương ứng
            if (bmi < 18.5) {
                classification = "Gầy";
                color = "#3498db"; // Xanh dương
            } else if (bmi >= 18.5 && bmi < 24.9) {
                classification = "Bình thường";
                color = "#2ecc71"; // Xanh lá
            } else if (bmi >= 24.9 && bmi < 29.9) {
                classification = "Thừa cân";
                color = "#e67e22"; // Cam
            } else {
                classification = "Béo phì";
                color = "#e74c3c"; // Đỏ
            }

            // Hiển thị kết quả trực tiếp lên giao diện
            resultDiv.style.display = "block";
            resultDiv.style.backgroundColor = color + "22"; // Thêm độ trong suốt cho background
            resultDiv.style.color = color;
            resultDiv.style.border = `1px solid ${color}`;
            resultDiv.innerHTML = `BMI của bạn: ${bmi}<br>Thể trạng: ${classification}`;
        }
    </script>
</body>
</html>